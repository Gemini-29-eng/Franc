// 🔎 Simuler un moteur de recherche
function search() {
  let input = document.getElementById("searchInput").value;
  let results = document.getElementById("results");

  results.innerHTML = "";

  if (input === "") {
    results.innerHTML = "<p>Veuillez écrire quelque chose.</p>";
    return;
  }

  // Simulation de résultats
  let fakeResults = [
    "Résultat 1 sur " + input,
    "Article lié à " + input,
    "Information importante sur " + input
  ];

  fakeResults.forEach(item => {
    let div = document.createElement("div");
    div.className = "card";
    div.innerHTML = "🔎 " + item;
    results.appendChild(div);
  });
}

