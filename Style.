body {
  font-family: Arial, sans-serif;
  margin: 0;
  background: #f4f4f4;
  text-align: center;
}

header {
  background: black;
  color: white;
  padding: 20px;
}

.search-box {
  margin: 20px;
}

input {
  width: 60%;
  padding: 10px;
  font-size: 16px;
}

button {
  padding: 10px 15px;
  background: black;
  color: white;
  border: none;
  cursor: pointer;
}

#results, #news {
  width: 70%;
  margin: auto;
  text-align: left;
}

.card {
  background: white;
  padding: 15px;
  margin: 10px;
  border-radius: 8px;
  box-shadow: 0 0 5px rgba(0,0,0,0.1);
}
